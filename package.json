{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "build": "npm run sitemap && vite build",
    "postbuild": "react-snap || echo 'react-snap prerender skipped (non-fatal)'",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons:generate": "node scripts/generate-icons.mjs",
    "i18n:check": "node scripts/check-i18n.mjs"
  },
  "reactSnap": {
    "source": "dist",
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "include": [
      "/",
      "/audio-tours",
      "/trips",
      "/causes",
      "/people",
      "/posts",
      "/login",
      "/signup",
      "/regions/nile-delta",
      "/regions/suez-canal",
      "/regions/upper-egypt",
      "/regions/frontiers"
    ]
  },
